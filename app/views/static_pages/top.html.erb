<div class="flex flex-col items-center justify-center min-h-screen bg-gray-900 p-4">
  
  <div class="w-full max-w-sm bg-white p-8 rounded-none shadow-2xl border-t-8 border-gray-900">
    
    <%# タイトル：明朝体っぽさを出し、あえて少し文字を詰め気味に %>
    <h1 class="text-4xl font-serif font-bold mb-2 text-gray-900 text-center tracking-tighter">
      明日から本気出す
    </h1>
    
    <%# サブタイトル：渋いアクセント %>
    <div class="flex items-center justify-center mb-8">
      <div class="h-px bg-gray-400 w-12 mr-2"></div>
      <p class="text-xs text-gray-500 uppercase tracking-widest">漢の生存報告</p>
      <div class="h-px bg-gray-400 w-12 ml-2"></div>
    </div>

    <%= form_with url: login_path, method: :post, local: true, class: "flex flex-col gap-4" do |f| %>
      <div>
        <%= f.label :email, "MAIL", class: "block text-[10px] font-bold text-gray-500 tracking-widest" %>
        <%= f.email_field :email, placeholder: "example@mail.com", class: "mt-1 border-b-2 border-gray-300 py-2 w-full focus:border-gray-900 outline-none transition" %>
      </div>

      <div>
        <%= f.label :password, "PASSWORD", class: "block text-[10px] font-bold text-gray-500 tracking-widest" %>
        <%= f.password_field :password, placeholder: "••••••••", class: "mt-1 border-b-2 border-gray-300 py-2 w-full focus:border-gray-900 outline-none transition" %>
      </div>

      <%= f.submit "さあ、始める", class: "mt-6 bg-gray-900 hover:bg-black text-white font-bold py-3 transition duration-300 cursor-pointer w-full tracking-widest" %>
    <% end %>

    <div class="mt-6 text-center text-xs text-gray-500">
      未登録の方は <%= link_to "新規登録", signup_path, class: "text-gray-900 font-bold underline underline-offset-4" %>
    </div>
  </div>

  <div class="mt-8 text-[10px] text-gray-600 tracking-widest">
    © 2026 ASHUHON CORP.
  </div>
</div>
