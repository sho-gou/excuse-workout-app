<div class="flex flex-col items-center justify-center min-h-screen bg-gray-50">
  <nav class="absolute top-4 right-4">
    <% if logged_in? %>
      <span class="text-gray-600 mr-4">ログイン中です</span>
      <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete }, class: "text-blue-500" %>
    <% else %>
      <%= link_to "ログイン", login_path, class: "text-blue-500 mr-4" %>
      <%= link_to "新規登録", signup_path, class: "text-blue-500" %>
    <% end %>
  </nav>
  
  <h1 class="text-4xl font-bold mb-8 text-gray-800">明日から本気出す</h1>

  <%= form_with url: "#", local: true, class: "flex flex-col gap-4 w-64" do |f| %>
    <div>
      <%= f.label :email, "Email", class: "block" %>
      <%= f.email_field :email, class: "border p-1 w-full rounded-lg" %>
    </div>

    <div>
      <%= f.label :password, "password", class: "block" %>
      <%= f.password_field :password, class: "border p-1 w-full rounded-lg" %>
    </div>

    <%= f.submit "signin", class: "bg-blue-500 text-white p-2 rounded" %>
  <% end %>

  <div class="mt-8 flex gap-4 text-sm text-gray-500">
    <%= link_to "利用規約", "#" %>
    <%= link_to "プライバシーポリシー", "#" %>
    <%= link_to "お問い合わせ", "#" %>
  </div>
</div>

