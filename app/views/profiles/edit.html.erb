<div class="flex flex-col items-center justify-center min-h-screen bg-gray-50">
  <h1 class="text-3xl font-bold mb-6">プロフィール編集</h1>

  <%= form_with model: @profile, url: profile_path, method: :patch, class: "flex flex-col gap-4 w-64 bg-white p-6 rounded-lg shadow-md" do |f| %>
    <div>
      <%= f.label :fitness_goal, '目標', class: "block text-sm font-medium" %>
      <%= f.text_field :fitness_goal, class: "border p-2 w-full rounded-lg" %>
    </div>

    <div>
      <%= f.label :tiny_menu, 'やる事', class: "block text-sm font-medium" %>
      <%= f.text_field :tiny_menu, class: "border p-2 w-full rounded-lg" %>
    </div>

    <%= f.submit "設定保存", class: "bg-blue-500 text-white p-2 rounded-lg cursor-pointer hover:bg-blue-600" %>
  <% end %>
</div>
