<div class="max-w-md mx-auto py-10 px-4">
  <%# ヘッダー %>
  <div class="mb-8 border-l-8 border-gray-900 pl-6">
    <h1 class="text-3xl font-black tracking-tighter text-gray-900 uppercase">SETTINGS</h1>
    <p class="text-xs font-bold text-gray-500 tracking-widest mt-1">活動目標変更</p>
  </div>

  <%# フォーム本体 %>
  <div class="bg-white border-2 border-gray-900 p-8 shadow-xl">
    <%= form_with model: @profile, url: profile_path, method: :patch, class: "space-y-8" do |f| %>
      
      <div>
        <label class="block text-[10px] font-black text-gray-400 tracking-widest uppercase mb-2">Primary Goal</label>
        <%= f.text_field :fitness_goal, class: "w-full border-2 border-gray-900 p-3 font-bold text-gray-900 outline-none focus:bg-gray-50 transition" %>
      </div>

      <div>
        <label class="block text-[10px] font-black text-gray-400 tracking-widest uppercase mb-2">Daily Task</label>
        <%= f.text_field :tiny_menu, class: "w-full border-2 border-gray-900 p-3 font-bold text-gray-900 outline-none focus:bg-gray-50 transition" %>
      </div>

      <div class="pt-2">
        <%= f.submit "設定保存", 
            class: "w-full py-4 bg-gray-900 text-white font-black tracking-widest uppercase hover:bg-black transition cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div class="mt-8 text-center">
    <%= link_to "メインメニューに戻る", root_path, class: "text-[10px] font-bold text-gray-400 hover:text-gray-900 underline uppercase tracking-widest" %>
  </div>
</div>
