<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Myapp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <%# 認証関連ページではヘッダーを非表示 %>
    <% is_auth_page = (controller_name == 'static_pages' && action_name == 'top') || 
                      (controller_name == 'users' && ['new', 'create'].include?(action_name)) %>

    <% unless is_auth_page %>
      <header class="border-b-4 border-gray-900 py-6 px-4 bg-white">
        <div class="max-w-5xl mx-auto flex items-center justify-between">
          
          <%# ロゴ部分を呼び出し %>
          <%= link_to root_path do %>
            <%= render 'layouts/logo' %>
          <% end %>
          
          <% if logged_in? %>
            <nav class="flex items-center gap-6">
              <%= link_to "REPORT", root_path, class: "text-[10px] font-black text-gray-900 hover:underline tracking-widest uppercase" %>
              <%= link_to "CALENDAR", calendar_survival_logs_path, class: "text-[10px] font-black text-gray-900 hover:underline tracking-widest uppercase" %>
              <%= link_to "MISSION SETTINGS", profile_path, class: "text-[10px] font-black text-gray-900 hover:underline tracking-widest uppercase" %>
              
              <%= link_to "LOGOUT", logout_path, data: { turbo_method: :delete }, 
                          class: "text-[10px] font-black text-white bg-gray-900 px-4 py-2 hover:bg-black transition tracking-widest uppercase" %>
            </nav>
          <% end %>
        </div>
      </header>
    <% end %>

    <main class="max-w-5xl mx-auto p-4">
      <%# フラッシュメッセージ：少し無骨なスタイルに調整 %>
      <% flash.each do |message_type, message| %>
        <div class="p-4 mb-4 text-[10px] font-bold uppercase tracking-widest border-2 border-gray-900 <%= message_type == 'notice' ? 'bg-gray-100 text-gray-900' : 'bg-red-900 text-white' %>">
          <%= message %>
        </div>
      <% end %>
      
      <%= yield %>
    </main>
  </body>
</html>
