<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Myapp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <header class="bg-white shadow-sm border-b p-4">
      <div class="flex items-center gap-x-6">
        <% if logged_in? %>
          <div class="text-sm text-gray-500 mr-2">ログイン中</div>
          
          <%= link_to "生存報告", root_path, class: "text-teal-600 font-bold hover:underline px-2" %>
          <%= link_to "プロフィール", edit_profile_path, class: "text-blue-600 font-bold hover:underline px-2" %>
          
          <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete }, 
                      class: "px-4 py-1 border border-red-500 text-red-500 rounded-full hover:bg-red-500 hover:text-white transition ml-auto" %>
        <% else %>
          <%= link_to "ログイン", login_path, class: "text-blue-600 px-2" %>
          <%= link_to "新規登録", signup_path, class: "text-blue-600 px-2" %>
        <% end %>
      </div>
    </header>

    <main class="p-4">
      <%# フラッシュメッセージ表示エリア %>
      <% flash.each do |message_type, message| %>
        <div class="p-4 mb-4 text-sm rounded-lg <%= message_type == 'notice' ? 'bg-green-100 text-green-800 border border-green-400' : 'bg-red-100 text-red-800 border border-red-400' %>">
          <%= message %>
        </div>
      <% end %>
      
      <%= yield %>
    </main>
  </body>
</html>
