<div class="flex flex-col items-center justify-center min-h-screen bg-gray-50">
  <h1 class="text-4xl font-bold mb-8 text-gray-800">明日から本気出す</h1>

  <%# ログインフォーム %>
  <%= form_with url: login_path, method: :post, class: "flex flex-col gap-4 w-64 bg-white p-8 rounded-lg shadow-md" do |f| %>
    <div>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, class: "border p-2 w-full rounded-lg focus:ring-2 focus:ring-blue-400 outline-none" %>
    </div>

    <div>
      <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password, class: "border p-2 w-full rounded-lg focus:ring-2 focus:ring-blue-400 outline-none" %>
    </div>

    <%= f.submit "サインイン", class: "bg-blue-500 text-white p-2 rounded-lg cursor-pointer hover:bg-blue-600 transition-colors" %>
  <% end %>

  <%# リンク類 %>
  <div class="mt-8 flex gap-4 text-sm text-gray-500">
    <%= link_to "利用規約", "#", class: "hover:underline" %>
    <%= link_to "プライバシーポリシー", "#", class: "hover:underline" %>
    <%= link_to "お問い合わせ", "#", class: "hover:underline" %>
  </div>
</div>
