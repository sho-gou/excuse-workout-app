<div class="flex flex-col items-center justify-center min-h-screen bg-gray-50">
  <h1 class="text-4xl font-bold mb-8 text-gray-800">ユーザー登録</h1>

  <%= form_with model: @user, url: users_path, local: true, class: "flex flex-col gap-4 w-64 bg-white p-8 rounded-lg shadow-md" do |f| %>
    <div>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, class: "border p-2 w-full rounded-lg focus:ring-2 focus:ring-blue-400 outline-none" %>
    </div>

    <div>
      <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password, class: "border p-2 w-full rounded-lg focus:ring-2 focus:ring-blue-400 outline-none" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Password Confirmation", class: "block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password_confirmation, class: "border p-2 w-full rounded-lg focus:ring-2 focus:ring-blue-400 outline-none" %>
    </div>

    <%= f.submit "登録する", class: "bg-blue-500 text-white p-2 rounded-lg cursor-pointer hover:bg-blue-600 transition-colors" %>
  <% end %>

  <div class="mt-8 text-sm text-gray-500">
    すでにアカウントをお持ちですか？ <%= link_to "ログイン", login_path, class: "text-blue-500 hover:underline" %>
  </div>
</div>
