<div class="w-full py-10 px-4">
  <div class="max-w-5xl mx-auto">
    
    <%# タイトルエリア %>
    <div class="mb-8 border-l-8 border-gray-900 pl-6">
      <h1 class="text-3xl font-black tracking-tighter text-gray-900 uppercase">MISSION CALENDAR</h1>
      <p class="text-xs font-bold text-gray-500 tracking-widest mt-1">月間生存戦績</p>
    </div>

    <%# カレンダー本体 %>
    <div class="w-full bg-white border-2 border-gray-900 shadow-xl overflow-hidden">
      <%= month_calendar events: @survival_logs do |date, logs| %>
        
        <%# group クラスを追加してホバー時のトリガーにする %>
        <div class="group h-28 flex flex-col p-2 border border-gray-200 <%= date == Date.today ? 'bg-gray-50' : '' %>">
          
          <%# 【ここを修正】過去の未報告日を赤字で強調 %>
          <% is_unfinished = (date < Date.today && logs.blank?) %>
          <%= link_to date.day, survival_logs_path(reported_on: date), 
              class: "text-sm font-black transition-colors #{is_unfinished ? 'text-red-500 underline' : 'text-gray-400 hover:text-gray-900'}" %>
          
          <div class="w-full flex flex-col space-y-1 mt-2">
            <% logs.each do |log| %>
              <div class="px-1 py-0.5 text-[9px] font-bold tracking-tighter uppercase text-center
                          <%= log.report_status.to_i == 1 ? 'bg-gray-900 text-white' : 'border border-gray-900 text-gray-900' %>">
                <%= log.report_status.to_i == 1 ? "実行" : "断念" %>
              </div>

              <%# ホバー時のみ表示される編集・削除ボタン %>
              <div class="flex gap-2 justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <%= link_to "✎", edit_survival_log_path(log), class: "text-gray-400 hover:text-blue-500" %>
                <%= button_to "×", survival_log_path(log), method: :delete, data: { confirm: "削除しますか？" }, class: "text-gray-400 hover:text-red-500 bg-transparent border-0 p-0 cursor-pointer" %>
              </div>

              <% if log.excuse.present? %>
                <div class="text-[8px] text-gray-500 truncate italic tracking-tight text-center">
                  <%= log.excuse.name %>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# 戻るリンク %>
    <div class="mt-8 text-center">
      <%= link_to "REPORTへ", survival_logs_path, class: "text-[10px] font-bold text-gray-400 hover:text-gray-900 underline uppercase tracking-widest" %>
    </div>
  </div>
</div>
