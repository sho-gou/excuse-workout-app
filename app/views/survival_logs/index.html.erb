<div class="max-w-md mx-auto py-10 px-4">
  <div class="mb-8 border-l-8 border-gray-900 pl-6">
    <h1 class="text-3xl font-black tracking-tighter text-gray-900 uppercase">Survival Report</h1>
    <p class="text-xs font-bold text-gray-500 tracking-widest mt-1"><%= @selected_date %></p>
  </div>

  <div class="space-y-8">
    <%# 実行ボタン（無骨なブロック体） %>
    <%= button_to "実行", survival_logs_path(survival_log: { report_status: 1, reported_on: @selected_date }), 
        method: :post, 
        class: "w-full py-6 text-xl font-black text-white bg-gray-900 hover:bg-black transition tracking-widest uppercase" %>

    <%# サボるフォーム（削ぎ落とされたインターフェース） %>
    <div class="border-t-2 border-gray-900 pt-8">
      <%= form_with model: @survival_log, url: survival_logs_path, local: true do |f| %>
        <%= f.hidden_field :reported_on, value: @selected_date %>
        <%= f.hidden_field :report_status, value: -1 %>
        
        <div class="mb-6">
          <p class="text-[10px] font-black text-gray-400 tracking-widest uppercase mb-4">選択：言い訳</p>
          <div class="space-y-2">
            <% Excuse.all.each do |excuse| %>
              <label class="flex items-center p-4 bg-white border-2 border-gray-200 cursor-pointer hover:border-gray-900 transition">
                <%= f.radio_button :excuse_id, excuse.id, class: "appearance-none w-4 h-4 border-2 border-gray-400 checked:bg-gray-900 checked:border-gray-900 mr-4" %>
                <span class="text-sm font-bold text-gray-700"><%= excuse.name %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%= f.submit "断念", 
            class: "w-full py-4 text-sm font-black text-gray-500 border-2 border-gray-200 hover:bg-gray-900 hover:text-white hover:border-gray-900 transition tracking-widest uppercase cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <div class="mt-12 text-center">
    <%= link_to "戻る", calendar_survival_logs_path, class: "text-[10px] font-bold text-gray-400 hover:text-gray-900 underline uppercase tracking-widest" %>
  </div>
</div>
